[Unit]
Description=AdbWireGuard Broker (user)
After=default.target

[Service]
Type=simple
WorkingDirectory=%h/adbwireguard-broker/current
ExecStart=%h/adbwireguard-broker/current/AdbWireGuardRelay
Restart=always
RestartSec=2
Environment=ASPNETCORE_URLS=http://127.0.0.1:25127
EnvironmentFile=%h/.config/adbwireguard-broker.env

[Install]
WantedBy=default.target
